# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/pos_system

# JWT Configuration (CHANGE IN PRODUCTION!)
JWT_SECRET=your_jwt_secret_key_change_in_production_use_at_least_32_characters
JWT_EXPIRE=7d

# CORS Configuration (comma-separated multiple URLs)
FRONTEND_URL=http://localhost:5173,https://your-app.vercel.app

# Mailjet Email Configuration (for OTP & notifications)
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
SENDER_EMAIL=your_verified_email@gmail.com
SENDER_NAME=POS System

# Optional: Email Configuration (for notifications)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# Optional: Stripe Configuration (for payment processing)
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
