# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration
# For local development: mongodb://localhost:27017/pos_system
# For production: mongodb+srv://username:password@cluster.mongodb.net/pos_system
MONGODB_URI=mongodb://localhost:27017/pos_system

# JWT Configuration
# IMPORTANT: Use a strong secret in production (at least 32 random characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_change_in_production_use_at_least_32_characters
JWT_EXPIRE=7d

# CORS Configuration
# Frontend URL (change in production)
FRONTEND_URL=http://localhost:5173

# Optional: Email Configuration (for notifications)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# Optional: Stripe Configuration (for payment processing)
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
